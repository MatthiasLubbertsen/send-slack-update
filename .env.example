# Poort waarop de lokale Express server draait
PORT=3000

# Bot User OAuth Token (begint met xoxb-)
# Te vinden in: https://api.slack.com/apps -> jouw app -> "OAuth & Permissions"
# -> "Bot User OAuth Token"
# Verplicht.
SLACK_BOT_TOKEN=xoxb-...

# App-Level Token voor Socket Mode (begint met xapp-)
# Te vinden in: https://api.slack.com/apps -> jouw app -> "Basic Information"
# -> "App-Level Tokens" -> token met scope "connections:write"
# Verplicht.
SLACK_APP_TOKEN=xapp-...

# Het Slack kanaal waar de update naartoe gepost wordt.
# Dit moet de Channel ID zijn (bv. C0123456789), niet de kanaalnaam.
# Te vinden door in Slack het kanaal te openen -> naam bovenaan klikken
# -> onderaan de "About" tab staat de Channel ID.
# Verplicht.
SLACK_CHANNEL_ID=C0123456789

# De ID van de usergroup die bovenaan het bericht gementioned wordt
# (bv. @matthias-day). Te vinden via Slack -> People & user groups
# -> klik op de usergroup -> ID staat in de URL of via de Slack API
# methode usergroups.list.
# Verplicht.
SLACK_USERGROUP_ID=S0AK8LYJ8FR
